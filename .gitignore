/unarr
/unarr.exe

# Test binary
*.test

# Output of go coverage
*.out
coverage.html

# Go profiling
*.prof

# Go workspace
go.work
go.work.sum

# Go debugger (delve)
__debug_bin*

# Environment files (may contain API keys)
.env
.env.*

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# GoReleaser
dist/
dist-ffbinaries/

# Docker
tmp/
config/
dist-ffbinaries/

# Claude Code: global ~/.gitignore excludes .claude/ by default, which hides
# project-shared agents/commands/hooks. Override here to commit the shared
# pieces (agents, commands, hooks, settings.json). Keep per-user state local.
!.claude/
!.claude/agents/
!.claude/agents/**
!.claude/commands/
!.claude/commands/**
!.claude/hooks/
!.claude/hooks/**
!.claude/settings.json
.claude/settings.local.json
.claude/projects/
.claude/scheduled_tasks.lock
.claude/skills/